# ─────────────────────────────────────────────
# CryBaby Backend — Environment Variables
# Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Dev: leave as SQLite (no setup needed)
DATABASE_URL=sqlite:///./crybaby.db
# Prod (Render / Railway / Fly.io Postgres):
# DATABASE_URL=postgresql://user:password@host:5432/crybaby

# ── Auth ──────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Voice / AI (optional until Milestone 4) ───
# Use claude-haiku-4-5-20251001 — costs ~$0.0001 per voice command.
# Free alternative: swap to Google Gemini Flash (gemini-1.5-flash, free tier).
# Leave blank to disable voice feature.
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# ── Push Notifications (optional until Milestone 3) ─
# Generate once: cd backend && python scripts/gen_vapid.py
# Leave blank to disable push notifications during early dev.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=you@example.com

# ── Cloudinary (image uploads) ────────────────
# Sign up free at cloudinary.com → Dashboard → copy these 3 values.
# Without these, avatar uploads will return a 500 error.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS ──────────────────────────────────────
# Dev: keep as-is. Prod: set to your Netlify URL.
CORS_ORIGINS=["http://localhost:5173"]
